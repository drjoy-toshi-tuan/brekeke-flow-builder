{
  "_about": "東京都立豊島 診療フロー P7 連結テスト — branch_spec 定義",
  "facility": "東京都立豊島",
  "flow": "診療",
  "entry_flow": "M｜診療",

  "selector": {
    "module": "__テストセレクタ"
  },

  "inject_pools": {
    "_comment": "ケース index でローテーション。branch.inject に明示されていないフィールドに自動付与。",
    "入力_患者_氏名": [
      "ヤマダタロウ", "サトウハナコ", "タナカイチロウ", "スズキジロウ",
      "ワタナベアキコ", "イトウシンジ", "カワカミメグミ", "ハシモトケイイチ",
      "キムラサチコ", "オオタユウジ", "フジタマリコ", "マツモトコウジ",
      "ナカムラユキ", "ヨシダケンタ", "コバヤシナオコ", "ニシムラタカシ"
    ],
    "入力_生年月日": [
      "19800101", "昭和40年3月15日", "19651225", "平成2年7月20日",
      "19901201", "昭和55年11月11日", "19750509", "平成8年1月30日",
      "19850815", "昭和62年4月5日", "19700620", "平成15年9月9日",
      "19951010", "昭和47年8月25日", "19880303", "平成12年12月12日"
    ],
    "入力_患者_診察券番号": [
      "1234567", "9876543", "4567890", "2345678",
      "8765432", "3456789", "7654321", "5678901",
      "1357924", "2468013", "9012345", "6789012",
      "3571246", "8024689", "4680135", "7913580"
    ],
    "入力_連絡先電話番号（固定）": [
      "09012345678", "08087654321", "07099998888", "09011112222",
      "08033334444", "07055556666", "09077778888", "08099990000",
      "07011223344", "09055667788", "08022334455", "07044556677",
      "09088990011", "08044556677", "07066778899", "09033445566"
    ]
  },

  "defaults": {
    "_about": "サブフローSTTの既定注入値。inject_pools にないフィールドの既定。",
    "_order": [
      "入力_患者_診察券番号",
      "入力_復唱_診察券",
      "入力_患者_氏名",
      "入力_生年月日",
      "入力_復唱_患者_生年月日",
      "復唱_患者_生年月日",
      "入力_連絡先電話番号（固定）",
      "入力_患者_電話番号（確認）",
      "入力_復唱-入力_連絡先電話番号",
      "入力_連絡先電話番号_非通知",
      "入力_復唱-入力_非通知",
      "入力_変更_診療科",
      "入力_復唱_診療科",
      "入力_受診歴",
      "入力_予約_紹介状有無",
      "入力_選定療養費",
      "入力－診察か否か",
      "入力_症状",
      "入力_希望日①",
      "入力_現在の予約日",
      "入力_不可日",
      "入力_理由",
      "入力_相談_問合せ",
      "入力_追加の質問",
      "入力_復唱_用件",
      "入力_用件",
      "入力－予約内容"
    ],
    "_fallback": ["NO_RESULT"],
    "入力_復唱_診察券":              ["はい"],
    "入力_復唱_患者_生年月日":       ["はい"],
    "復唱_患者_生年月日":            ["はい"],
    "入力_患者_電話番号（確認）":    ["はい"],
    "入力_復唱-入力_連絡先電話番号": ["はい"],
    "入力_連絡先電話番号_非通知":    ["09012345678"],
    "入力_復唱-入力_非通知":         ["はい"],
    "入力_復唱_診療科":              ["はい"],
    "入力_予約_紹介状有無":          ["なし"],
    "入力_選定療養費":               ["なし"],
    "入力－診察か否か":              ["診察"],
    "入力_症状":                     ["腹痛があります"],
    "入力_希望日①":                  ["来週の月曜日"],
    "入力_現在の予約日":             ["20260901"],
    "入力_不可日":                   ["なし"],
    "入力_理由":                     ["都合が悪くなった"],
    "入力_相談_問合せ":              ["駐車場はありますか"],
    "入力_追加の質問":               ["いいえ"],
    "入力_復唱_用件":                ["はい"],
    "入力－予約内容":                ["確認します"]
  },

  "branches": [
    {
      "id": "1",
      "label": "予約_再診_整形外科_診察予約",
      "_note": "用件=予約 → 診療科=整形外科 → 受診歴=再診 → 診察か否か=診察 → 情報収集 → 終話①",
      "inject": {
        "入力_用件":          ["予約"],
        "入力_変更_診療科":   ["整形外科"],
        "入力_受診歴":        ["再診"],
        "入力－診察か否か":   ["診察"],
        "入力_希望日①":       ["来週の月曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "2",
      "label": "予約_再診_皮膚科_その他",
      "_note": "再診 → 診察か否か=その他（検査・処置など）分岐",
      "inject": {
        "入力_用件":          ["予約"],
        "入力_変更_診療科":   ["皮膚科"],
        "入力_受診歴":        ["再診"],
        "入力－診察か否か":   ["その他"],
        "入力_症状":          ["湿疹が出ています"],
        "入力_希望日①":       ["来週の火曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "3",
      "label": "予約_初診_眼科_紹介状あり",
      "_note": "初診 → 紹介状=あり → 希望日② ルートを確認",
      "inject": {
        "入力_用件":             ["予約"],
        "入力_変更_診療科":      ["眼科"],
        "入力_受診歴":           ["初診"],
        "入力_予約_紹介状有無":  ["あり"],
        "入力_希望日①":          ["来週の水曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "4",
      "label": "予約_初診_泌尿器科_紹介状なし_選定あり",
      "_note": "初診 → 紹介状=なし → 選定療養費=あり → 希望日② ルート",
      "inject": {
        "入力_用件":             ["予約"],
        "入力_変更_診療科":      ["泌尿器科"],
        "入力_受診歴":           ["初診"],
        "入力_予約_紹介状有無":  ["なし"],
        "入力_選定療養費":       ["あり"],
        "入力_希望日①":          ["来週の木曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "5",
      "label": "予約_初診_循環器内科_紹介状なし_選定なし",
      "_note": "初診 → 紹介状=なし → 選定療養費=なし → 希望日① ルート",
      "inject": {
        "入力_用件":             ["予約"],
        "入力_変更_診療科":      ["循環器内科"],
        "入力_受診歴":           ["初診"],
        "入力_予約_紹介状有無":  ["なし"],
        "入力_選定療養費":       ["なし"],
        "入力_希望日①":          ["来週の金曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "6",
      "label": "予約_救急科",
      "_note": "診療科=救急科 → SMS送信 → 終話（救急科は予約不可ルート）",
      "inject": {
        "入力_用件":           ["予約"],
        "入力_変更_診療科":    ["救急科"]
      },
      "expect": {"終端": "終話", "checkpoints": ["sms-救急科"]}
    },
    {
      "id": "7",
      "label": "予約_初診_診療科_分からない",
      "_note": "診療科=分からない → save-分からない ルート確認",
      "inject": {
        "入力_用件":           ["予約"],
        "入力_変更_診療科":    ["分からない"],
        "入力_受診歴":         ["初診"],
        "入力_予約_紹介状有無":["なし"],
        "入力_選定療養費":     ["なし"],
        "入力_希望日①":        ["今週の水曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["save-分からない"]}
    },
    {
      "id": "8",
      "label": "予約_受診歴_聴取失敗",
      "_note": "受診歴ノードでリトライ上限 → 切断_受診歴 or 終話_受診歴＿なし",
      "inject": {
        "入力_用件":           ["予約"],
        "入力_変更_診療科":    ["内科"],
        "入力_受診歴":         ["NO_RESULT", "NO_RESULT", "NO_RESULT"]
      },
      "expect": {"終端": "切断_受診歴", "checkpoints": []}
    },
    {
      "id": "9",
      "label": "変更_外科_通常",
      "_note": "用件=変更 → 診療科=外科 → 現在の予約日 → 希望日 → 情報収集 → 終話",
      "inject": {
        "入力_用件":           ["変更"],
        "入力_変更_診療科":    ["外科"],
        "入力_現在の予約日":   ["20260901"],
        "入力_希望日①":        ["来週の月曜日"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-変更"]}
    },
    {
      "id": "10",
      "label": "変更_救急科",
      "_note": "変更フロー → 診療科=救急科 → 変更不可終話",
      "inject": {
        "入力_用件":           ["変更"],
        "入力_変更_診療科":    ["救急科"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-不可"]}
    },
    {
      "id": "11",
      "label": "変更_脳神経外科_不可日あり",
      "_note": "変更 → 脳神経外科 → 現在の予約日=不明 → 不可日指定あり",
      "inject": {
        "入力_用件":           ["変更"],
        "入力_変更_診療科":    ["脳神経外科"],
        "入力_現在の予約日":   ["分からない"],
        "入力_不可日":         ["来週の木曜日"],
        "入力_希望日①":        ["来週の水曜日"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-変更"]}
    },
    {
      "id": "12",
      "label": "キャンセル_形成外科_通常",
      "_note": "用件=キャンセル → 診療科=形成外科 → 現在の予約日 → 理由 → 終話",
      "inject": {
        "入力_用件":           ["キャンセル"],
        "入力_変更_診療科":    ["形成外科"],
        "入力_現在の予約日":   ["20260815"],
        "入力_理由":           ["仕事の都合がつかなくなった"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-キャンセル"]}
    },
    {
      "id": "13",
      "label": "キャンセル_救急科",
      "_note": "キャンセルフロー → 診療科=救急科 → キャンセル不可終話",
      "inject": {
        "入力_用件":           ["キャンセル"],
        "入力_変更_診療科":    ["救急科"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-不可"]}
    },
    {
      "id": "14",
      "label": "キャンセル_産婦人科_理由未回答",
      "_note": "キャンセル → 理由ノードでリトライ上限 → 理由なしで通過するか確認",
      "inject": {
        "入力_用件":           ["キャンセル"],
        "入力_変更_診療科":    ["産婦人科"],
        "入力_現在の予約日":   ["20260920"],
        "入力_理由":           ["NO_RESULT", "NO_RESULT", "体調が悪い"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-キャンセル"]}
    },
    {
      "id": "15",
      "label": "お問い合わせ_FAQ成功",
      "_note": "用件=お問い合わせ → FAQ検索成功 → save-details 終話",
      "inject": {
        "入力_用件":           ["お問い合わせ"],
        "入力_相談_問合せ":    ["診察時間を教えてください"],
        "入力_追加の質問":     ["いいえ"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-details"]}
    },
    {
      "id": "16",
      "label": "お問い合わせ_FAQ失敗",
      "_note": "FAQ検索 NO_RESULT → 相談_FAQ失敗 端末ノード",
      "inject": {
        "入力_用件":           ["お問い合わせ"],
        "入力_相談_問合せ":    ["NO_RESULT"]
      },
      "expect": {"終端": "終話", "checkpoints": ["相談_FAQ失敗"]}
    },
    {
      "id": "17",
      "label": "お問い合わせ_追加質問あり",
      "_note": "FAQ成功後 → 追加質問=あり → もう一度 FAQ",
      "inject": {
        "入力_用件":           ["お問い合わせ"],
        "入力_相談_問合せ":    ["駐車場はありますか"],
        "入力_追加の質問":     ["はい"],
        "入力_相談_問合せ②": ["支払い方法を教えてください"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-details"]}
    },
    {
      "id": "18",
      "label": "予約_再診_精神科_診察_希望日リトライ",
      "_note": "希望日①で NO_RESULT → リトライ後成功",
      "inject": {
        "入力_用件":           ["予約"],
        "入力_変更_診療科":    ["精神科"],
        "入力_受診歴":         ["再診"],
        "入力－診察か否か":    ["診察"],
        "入力_希望日①":        ["NO_RESULT", "来週の火曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "19",
      "label": "予約_初診_麻酔科_紹介状YES_不可日なし",
      "_note": "初診 → 紹介状あり → 不可日指定なし → 希望日だけ",
      "inject": {
        "入力_用件":             ["予約"],
        "入力_変更_診療科":      ["麻酔科"],
        "入力_受診歴":           ["初診"],
        "入力_予約_紹介状有無":  ["あり"],
        "入力_不可日":           ["なし"],
        "入力_希望日①":          ["今週の金曜日"]
      },
      "expect": {"終端": "終話①", "checkpoints": ["SAVE-予約"]}
    },
    {
      "id": "20",
      "label": "変更_小児科_現在の予約日_聴取失敗",
      "_note": "変更 → 現在の予約日ノードでリトライ上限 → 理由なしで次へ",
      "inject": {
        "入力_用件":             ["変更"],
        "入力_変更_診療科":      ["小児科"],
        "入力_現在の予約日":     ["NO_RESULT", "NO_RESULT", "NO_RESULT"],
        "入力_希望日①":          ["来週の月曜日"]
      },
      "expect": {"終端": "終話", "checkpoints": ["save-変更"]}
    }
  ]
}
