{
  "_about": "福岡大学病院 診療_0708フロー P7 連結テスト — branch_spec 定義",
  "facility": "福岡大学",
  "flow": "診療_0708",
  "entry_flow": "M｜診療_0708",

  "selector": {
    "module": "__テストセレクタ"
  },

  "inject_pools": {
    "_comment": "ケース index でローテーション。branch.inject に明示されていないフィールドに自動付与。",
    "入力_患者名": [
      "ヤマダ タロウ", "サトウ ハナコ", "タナカ イチロウ", "スズキ ジロウ",
      "ワタナベ アキコ", "イトウ シンジ", "カワカミ メグミ", "ハシモト ケイイチ",
      "キムラ サチコ", "オオタ ユウジ", "フジタ マリコ", "マツモト コウジ"
    ],
    "入力_生年月日": [
      "19800101", "昭和40年3月15日", "19651225", "平成2年7月20日",
      "19901201", "昭和55年11月11日", "19750509", "平成8年1月30日",
      "19850815", "昭和62年4月5日", "19700620", "平成15年9月9日"
    ],
    "入力_診察券番号": [
      "1234567", "9876543", "4567890", "2345678",
      "8765432", "3456789", "7654321", "5678901",
      "1357924", "2468013", "9012345", "6789012"
    ],
    "入力_連絡先番号": [
      "09012345678", "08087654321", "07099998888", "09011112222",
      "08033334444", "07055556666", "09077778888", "08099990000",
      "07011223344", "09055667788", "08022334455", "07044556677"
    ]
  },

  "defaults": {
    "_about": "サブフローSTTの既定注入値。",
    "_order": [
      "入力_診察券番号",
      "入力_患者名",
      "入力_生年月日",
      "入力_復唱_生年月日",
      "入力_連絡先番号",
      "入力_連絡先番号2",
      "入力_電話番号再入力",
      "入力_復唱_電話番号",
      "入力_確認_再入力",
      "入力_診療科",
      "入力_ハートセンター",
      "入力_診療科②",
      "入力_最後の問い合わせ_携帯以外",
      "入力_変更_予約日",
      "入力_変更希望日",
      "入力_3診療日確認",
      "入力_用件"
    ],
    "_fallback": ["NO_RESULT"],
    "入力_復唱_生年月日":   ["はい"],
    "入力_連絡先番号2":     ["09012345678"],
    "入力_電話番号再入力":  ["09012345678"],
    "入力_復唱_電話番号":   ["はい"],
    "入力_確認_再入力":     ["はい"],
    "入力_診療科":          ["内科"],
    "入力_ハートセンター":  ["はい"],
    "入力_最後の問い合わせ_携帯以外": ["いいえ"],
    "入力_変更_予約日":     ["20260901"],
    "入力_変更希望日":      ["来週の月曜日"],
    "入力_3診療日確認":     ["3診療日以降"]
  },

  "branches": [
    {
      "id": "1",
      "label": "変更_内科_通常",
      "_note": "用件=変更 → 診療科=内科 → 変更予約日 → 変更希望日 → 個人情報 → 通話完了",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["内科"],
        "入力_変更_予約日":    ["20260901"],
        "入力_変更希望日":     ["来週の月曜日"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["save-変更_Status", "通話完了"]}
    },
    {
      "id": "2",
      "label": "確認_内科_FAQ問い合わせあり",
      "_note": "用件=確認 → 診療科②=内科 → FAQ問い合わせあり → save-FAQ → 通話完了",
      "inject": {
        "入力_用件":          ["確認"],
        "入力_診療科②":       ["内科"],
        "入力_最後の問い合わせ_携帯以外": ["診察時間を教えてください"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["save-FAQ", "通話完了"]}
    },
    {
      "id": "3",
      "label": "変更_外科_3診療日以内",
      "_note": "用件exhaust → 3診療日以内確認 → 切断_3診療日以内",
      "inject": {
        "入力_用件":          ["NO_RESULT", "NO_RESULT", "NO_RESULT"],
        "入力_3診療日確認":   ["3診療日以内"]
      },
      "expect": {"終端": "切断_3診療日以内", "checkpoints": ["切断_3診療日以内"]}
    },
    {
      "id": "4",
      "label": "用件exhaust_3診療日以降_診療科_完走",
      "_note": "用件exhaust → 3診療日以降 → 診療科 → 個人情報 → 通話完了",
      "inject": {
        "入力_用件":          ["NO_RESULT", "NO_RESULT", "NO_RESULT"],
        "入力_3診療日確認":   ["3診療日以降"],
        "入力_診療科②":       ["外科"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "5",
      "label": "変更_ハートセンター",
      "_note": "診療科=ハートセンター → ハートセンターサブ分岐 → 通話完了",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["ハートセンター"],
        "入力_診療科":         ["内科"],
        "入力_変更_予約日":    ["20260915"],
        "入力_変更希望日":     ["来週の火曜日"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "6",
      "label": "確認_脳神経外科_FAQ問い合わせなし",
      "_note": "用件=確認 → 診療科=脳神経外科 → FAQ問い合わせなし",
      "inject": {
        "入力_用件":          ["確認"],
        "入力_診療科②":       ["脳神経外科"],
        "入力_最後の問い合わせ_携帯以外": ["いいえ"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "7",
      "label": "変更_皮膚科_変更予約日リトライ",
      "_note": "変更予約日 → NO_RESULT → リトライ後成功",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["皮膚科"],
        "入力_変更_予約日":    ["NO_RESULT", "20260920"],
        "入力_変更希望日":     ["来週の水曜日"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "8",
      "label": "確認_整形外科_FAQ成功",
      "_note": "確認フロー → FAQ検索成功 → save-FAQ2",
      "inject": {
        "入力_用件":          ["確認"],
        "入力_診療科②":       ["整形外科"],
        "入力_最後の問い合わせ_携帯以外": ["駐車場はありますか"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["save-FAQ2", "通話完了"]}
    },
    {
      "id": "9",
      "label": "変更_眼科_変更希望日exhaust",
      "_note": "変更希望日でリトライ上限 → jump-診療科",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["眼科"],
        "入力_変更_予約日":    ["20260925"],
        "入力_変更希望日":     ["NO_RESULT", "NO_RESULT", "NO_RESULT"]
      },
      "expect": {"終端": "通話完了", "checkpoints": []}
    },
    {
      "id": "10",
      "label": "変更_耳鼻咽喉科_生年月日リトライ",
      "_note": "個人情報 → 生年月日リトライ後成功",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["耳鼻咽喉科"],
        "入力_変更_予約日":    ["20261001"],
        "入力_変更希望日":     ["来週の木曜日"],
        "入力_生年月日":       ["NO_RESULT", "19850101"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "11",
      "label": "変更_泌尿器科_連絡先入力",
      "_note": "着信=非通知 → 連絡先聴取ルート",
      "inject": {
        "入力_用件":          ["変更"],
        "入力_診療科②":       ["泌尿器科"],
        "入力_変更_予約日":    ["20261005"],
        "入力_変更希望日":     ["来週の金曜日"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    },
    {
      "id": "12",
      "label": "確認_循環器内科_FAQ2回目",
      "_note": "確認 → FAQ2回目のパス確認",
      "inject": {
        "入力_用件":          ["確認"],
        "入力_診療科②":       ["循環器内科"],
        "入力_最後の問い合わせ_携帯以外": ["持ち物を教えてください"]
      },
      "expect": {"終端": "通話完了", "checkpoints": ["通話完了"]}
    }
  ]
}
