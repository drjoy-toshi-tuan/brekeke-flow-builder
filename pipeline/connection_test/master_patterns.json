  "_version": "1.0",
  "inject_templates": {
    "normal": {
      "desc": "正常発話（1回で成功）",
      "seq": [
        "{value}"
      ]
    },
    "retry_once": {
      "desc": "1回リトライ→成功",
      "seq": [
        "NO_RESULT",
        "{value}"
      ]
    },
    "retry_twice": {
      "desc": "2回リトライ→成功",
      "seq": [
        "NO_RESULT",
        "NO_RESULT",
        "{value}"
      ]
    },
    "exhaust": {
      "desc": "全リトライ失敗→exhaust終端",
      "seq": [
        "NO_RESULT",
        "NO_RESULT",
        "NO_RESULT"
      ]
    },
    "echo_back_no": {
      "desc": "復唱NO→再聴取→成功",
      "seq": [
        "{value}",
        "{value}"
      ],
      "note": "復唱ノードに [いいえ, はい] を別途inject"
    },
    "timeout_once": {
      "desc": "TIMEOUT1回→成功",
      "seq": [
        "TIMEOUT",
        "{value}"
      ]
    }
  },
