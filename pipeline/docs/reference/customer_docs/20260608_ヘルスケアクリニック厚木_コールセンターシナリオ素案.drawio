        <mxCell id="yxE1OzltzCGTDaTNNFiJ-14" edge="1" parent="1" source="n14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="yxE1OzltzCGTDaTNNFiJ-13" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <object label="固定電話入電のみ&lt;div&gt;【連絡先・発信者番号確認】&lt;/div&gt;&lt;div&gt;ご連絡先は、今おかけの番号でよろしいですか？「はい、そうです」もしくは、「いいえ、違います」でお答えください。&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(33, 33, 33), rgb(209, 209, 209));&quot;&gt;違う時のみDTMF入力。&lt;/span&gt;&lt;/div&gt;" category="item" id="n15">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#616161;fontColor=#212121;fontSize=12;arcSize=30;strokeWidth=1.5;" vertex="1">
