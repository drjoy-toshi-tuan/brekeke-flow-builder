        </object>
        <object label="【氏名】『名前は、たなか たろうです』のようにお話しください。" category="item" id="n13">
          <mxCell parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#616161;fontColor=#212121;fontSize=12;arcSize=30;strokeWidth=1.5;" vertex="1">
