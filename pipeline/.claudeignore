# ============================================================
# .claudeignore — Claude Codeの自動探索から除外するファイル
# ============================================================
# ※ このファイルはClaudeの「読み込み」対象を制御するだけで、
#    subprocess実行（validator.py等のコマンド呼び出し）には影響しない。
#    明示的にパスを指定したReadも引き続き可能。

# ------------------------------------------------------------
# 大容量スクリプト（実行対象だが自動読み込みは不要）
# ------------------------------------------------------------
scripts/ui_server.py

# ------------------------------------------------------------
# 中間・一時ファイル
# ------------------------------------------------------------
output/logs/
output/tmp*/
output/temp_bivr/

# ------------------------------------------------------------
# ビルド済みBIVR（バイナリ系、読んでも意味がない）
# ------------------------------------------------------------
output/bivr/

# ------------------------------------------------------------
# テスト・デバッグ用一時出力
# ------------------------------------------------------------
output/TSHamaguchi_*/
output/json/_ref_*

# ------------------------------------------------------------
# メトリクス
# ------------------------------------------------------------
metrics.json

# ------------------------------------------------------------
# ワークツリースナップショット（過去セッションの残骸）
# ------------------------------------------------------------
.claude/worktrees/
