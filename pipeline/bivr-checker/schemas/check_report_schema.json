{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Check Report Schema",
  "description": "checker エージェントが出力するチェックレポートの構造化形式（JSON出力オプション用）",
  "type": "object",
  "required": ["facility_name", "timestamp", "summary", "issues"],
  "properties": {
    "facility_name": {
      "type": "string",
      "description": "施設名"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": ["critical", "warning", "info"],
      "properties": {
        "critical": { "type": "integer" },
        "warning": { "type": "integer" },
        "info": { "type": "integer" }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "aspect", "location", "description", "expected", "actual"],
        "properties": {
          "code": {
            "type": "string",
            "description": "チェックコード（CHK-XXX）"
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "WARNING", "INFO"]
          },
          "aspect": {
            "type": "string",
            "enum": [
              "pdf_alignment",
              "default_values",
              "pattern_compliance",
              "prompt_quality",
              "property_completeness"
            ],
            "description": "チェック5観点のどれか"
          },
          "location": {
            "type": "string",
            "description": "モジュール名 or Property.mdの該当箇所"
          },
          "description": {
            "type": "string",
            "description": "問題の説明"
          },
          "expected": {
            "type": "string",
            "description": "期待値（正しいあるべき姿）"
          },
          "actual": {
            "type": "string",
            "description": "現状値"
          },
          "fix_hint": {
            "type": "string",
            "description": "fixerへの修正方針"
          }
        }
      }
    }
  }
}
