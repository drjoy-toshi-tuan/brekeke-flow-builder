{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fix Log Schema",
  "description": "fixer エージェントが出力する修正ログの形式定義",
  "type": "object",
  "required": ["facility_name", "timestamp", "rounds", "summary"],
  "properties": {
    "facility_name": {
      "type": "string",
      "description": "施設名"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "rounds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "source", "fixes"],
        "properties": {
          "round": {
            "type": "integer",
            "description": "修正ラウンド番号"
          },
          "source": {
            "type": "string",
            "enum": ["validation", "check", "review"],
            "description": "修正の根拠となったレポート"
          },
          "fixes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "severity", "module", "file", "field", "before", "after", "reason"],
              "properties": {
                "code": {
                  "type": "string",
                  "description": "エラーコード（STT-001, PROP-001, CHK-001 等）"
                },
                "severity": {
                  "type": "string",
                  "enum": ["CRITICAL", "WARNING"]
                },
                "module": {
                  "type": "string",
                  "description": "修正対象モジュール名"
                },
                "file": {
                  "type": "string",
                  "description": "修正対象ファイル名"
                },
                "field": {
                  "type": "string",
                  "description": "修正対象フィールド（例: next[0].nextModuleName）"
                },
                "before": {
                  "description": "修正前の値"
                },
                "after": {
                  "description": "修正後の値"
                },
                "reason": {
                  "type": "string",
                  "description": "修正理由"
                },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"],
                  "description": "修正の確信度。lowの場合は人間確認推奨"
                }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_fixes", "critical_fixed", "warning_fixed", "categories"],
      "properties": {
        "total_fixes": { "type": "integer" },
        "critical_fixed": { "type": "integer" },
        "warning_fixed": { "type": "integer" },
        "categories": {
          "type": "object",
          "properties": {
            "default_value_completion": { "type": "integer" },
            "structural_fix": { "type": "integer" },
            "prompt_fix": { "type": "integer" },
            "naming_fix": { "type": "integer" },
            "property_fix": { "type": "integer" }
          }
        }
      }
    }
  }
}
