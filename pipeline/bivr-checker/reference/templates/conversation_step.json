{
  "_description": "会話ステップテンプレート: TTS → STT → OpenAI → Retry → save2db の5モジュール1セット",
  "_usage": "聴取項目ごとにこのテンプレートを複製し、モジュール名・パラメータを置換",
  "modules": {
    "確認_ITEM": {
      "layout": {"x": 200, "y": 0},
      "next": [{"condition": "^.*$", "label": "Next Module", "nextModuleName": "入力_ITEM"}],
      "subs": [{"moduleName": "save-ITEM", "label": "save-ITEM"}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "確認_ITEM",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Text To Speech$Text to speech",
      "params": {"stop_by_dtmf": "No", "category_words": "", "prompt": ""}
    },
    "入力_ITEM": {
      "layout": {"x": 200, "y": 150},
      "next": [
        {"condition": "^TIMEOUT$", "label": "timeout", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^ERROR$", "label": "error", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^NO_RESULT$", "label": "no_result", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^.+$", "label": "success", "nextModuleName": "OpenAI_ITEM"}
      ],
      "subs": [{"moduleName": "save-ITEM", "label": "save-ITEM"}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "入力_ITEM",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^External Integration$DTMF AmiVoice STT Input",
      "params": {
        "prompt": "{recstart}", "max_dtmf_length": "10", "retry": "2",
        "termdtmf": "#", "remove_term": "Yes", "stop_play_when_speech": "Yes"
      }
    },
    "OpenAI_ITEM": {
      "layout": {"x": 200, "y": 300},
      "next": [
        {"condition": "^TIMEOUT$", "label": "timeout", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^ERROR$", "label": "error", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^NO_RESULT$", "label": "no_result", "nextModuleName": "リトライ_ITEM"},
        {"condition": "^.+$", "label": "success", "nextModuleName": "TODO_NEXT"}
      ],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "OpenAI_ITEM",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^External Integration$generate_by_OpenAI",
      "params": {
        "contextName": "", "contextDisplayType": "TEXT",
        "promptTTS": "", "module": "入力_ITEM", "functionCall": "", "prompt": ""
      }
    },
    "リトライ_ITEM": {
      "layout": {"x": 450, "y": 150},
      "next": [
        {"condition": "true", "label": "Retry", "nextModuleName": "確認_ITEM"},
        {"condition": "false", "label": "No more", "nextModuleName": "TODO_NO_MORE"}
      ],
      "subs": [{"moduleName": "save-ITEM", "label": "save-ITEM"}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "リトライ_ITEM",
      "description": "",
      "matchingmethod": 0,
      "type": "drjoy^Text To Speech$Speech Retry Counter",
      "params": {
        "retry_count": "1",
        "prompt_true": "{tts_g:申し訳ございません。うまく聞き取りが出来ませんでした。再度、}",
        "prompt_false": ""
      }
    },
    "save-ITEM": {
      "layout": {"x": 700, "y": 150},
      "next": [],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "save-ITEM",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Persistence$save2db",
      "params": {"contextName": "", "contextDisplayType": "TEXT"}
    }
  }
}
