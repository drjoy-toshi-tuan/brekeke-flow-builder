{
  "_description": "冒頭チェーンテンプレート: wait → saveContextModel2DB → 冒頭TTS → incoming-classifier → 非通知分岐",
  "_usage": "施設名・コンテキストフィールド・acceptance_times有無を置換して使用",
  "modules": {
    "冒頭待ち時間": {
      "layout": {"x": 200, "y": 0},
      "next": [{"condition": "^.*$", "label": "Next Module", "nextModuleName": "コンテキスト設定"}],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "冒頭待ち時間",
      "description": "",
      "matchingmethod": 1,
      "type": "Custom$wait",
      "params": {"wait": ""}
    },
    "コンテキスト設定": {
      "layout": {"x": 200, "y": 150},
      "next": [{"condition": "^.*$", "label": "next", "nextModuleName": "冒頭"}],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "コンテキスト設定",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Persistence$saveContextModel2DB",
      "params": {"fields": "TODO_REPLACE_WITH_CONTEXT_FIELDS"}
    },
    "冒頭": {
      "layout": {"x": 200, "y": 300},
      "next": [{"condition": "^.*$", "label": "Next Module", "nextModuleName": "着信分類"}],
      "subs": [{"moduleName": "save-冒頭", "label": "save-冒頭"}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "冒頭",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Text To Speech$Text to speech",
      "params": {"stop_by_dtmf": "No", "category_words": "", "prompt": ""}
    },
    "save-冒頭": {
      "layout": {"x": 450, "y": 300},
      "next": [],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "save-冒頭",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Persistence$save2db",
      "params": {"contextName": "", "contextDisplayType": "TEXT"}
    },
    "着信分類": {
      "layout": {"x": 200, "y": 450},
      "next": [
        {"condition": "^非通知$", "label": "非通知", "nextModuleName": "終話_非通知"},
        {"condition": "^携帯$", "label": "携帯", "nextModuleName": "TODO_NEXT_MODULE"},
        {"condition": "^固定$", "label": "固定", "nextModuleName": "TODO_NEXT_MODULE"},
        {"condition": "^海外$", "label": "海外", "nextModuleName": "TODO_NEXT_MODULE"},
        {"condition": "^その他$", "label": "その他", "nextModuleName": "TODO_NEXT_MODULE"}
      ],
      "subs": [{"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}, {"moduleName": "", "label": ""}],
      "name": "着信分類",
      "description": "",
      "matchingmethod": 1,
      "type": "drjoy^Incoming$incoming-classifier",
      "params": {}
    }
  },
  "start": "冒頭待ち時間"
}
