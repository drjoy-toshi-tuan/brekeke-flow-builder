      "type": "@General$Script",
      "params": {
        "script": "var rawData = $runner.getModuleResult(\"電話番号正規化2\");\nvar d = rawData ? String(rawData).replace(/[^0-9]/g, \"\") : \"\";\n\n// 判定フラグ\nvar isMobile = false;\n\n// 携帯電話の判定：060, 070, 080, 090 から始まる11桁\nvar mobilePattern = /^0[6-9]0\\d{8}$/;\n\nif (mobilePattern.test(d)) {\n    isMobile = true;\n    // 携帯電話の場合の処理\n} else {\n    isMobile = false;\n    // それ以外（固定電話、050、020、フリーダイヤルなど）の場合の処理\n}\n\n$runner.setResult(isMobile ? \"MOBILE\" : \"OTHER\");"
      }
