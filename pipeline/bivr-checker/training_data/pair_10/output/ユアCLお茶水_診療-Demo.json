      "description": "Execute script specified at the module settings.",
      "matchingmethod": 1,
      "type": "@General$Script",
      "params": {
        "script": "// ==================================================================\r\nvar JavaDate = Java.type(\"java.util.Date\");\r\nvar SimpleDateFormat = Java.type(\"java.text.SimpleDateFormat\");\r\n// ==================================================================\r\n\r\n// 現在時刻を取得（yyyyMMddHHmm形式）\r\nvar dateFormat = new SimpleDateFormat(\"yyyyMMddHHmm\");\r\ndateFormat.setTimeZone(java.util.TimeZone.getTimeZone(\"Asia/Tokyo\"));\r\nvar dateStr = dateFormat.format(new JavaDate());\r\n\r\nvar hour   = parseInt(dateStr.substring(8,  10), 10);\r\nvar minute = parseInt(dateStr.substring(10, 12), 10);\r\nvar hhmm   = hour * 100 + minute;\r\n\r\n$runner.getLogger().info(\"[checkTimeRoute3] current datetime: \" + dateStr + \" hhmm=\" + hhmm);\r\n\r\n// 時間帯判定\r\nvar result;\r\n\r\nif (hhmm >= 830 && hhmm < 1100) {\r\n    result = \"AI電話\";\r\n} else if (hhmm >= 1100 && hhmm < 1300) {\r\n    result = \"代表転送\";\r\n} else {\r\n    result = \"営業時間外\";\r\n}\r\n\r\n$runner.getLogger().info(\"[checkTimeRoute3] hhmm=\" + hhmm + \" => \" + result);\r\n\r\n$runner.setResult(result);"
      }
