      "name": "script_曜日分岐",
      "description": "Execute script specified at the module settings.",
      "matchingmethod": 1,
      "type": "@General$Script",
      "params": {
        "script": "// ==================================================================\nvar URI = Java.type(\"java.net.URI\");\nvar HttpClient = Java.type(\"java.net.http.HttpClient\");\nvar HttpRequest = Java.type(\"java.net.http.HttpRequest\");\nvar HttpResponse = Java.type(\"java.net.http.HttpResponse\");\nvar Duration = Java.type(\"java.time.Duration\");\nvar JavaDate = Java.type(\"java.util.Date\");\nvar SimpleDateFormat = Java.type(\"java.text.SimpleDateFormat\");\n// ==================================================================\n\n// 現在時刻を取得（yyyyMMddHHmm形式）\nvar dateFormat = new SimpleDateFormat(\"yyyyMMddHHmm\");\ndateFormat.setTimeZone(java.util.TimeZone.getTimeZone(\"Asia/Tokyo\"));\nvar dateStr = dateFormat.format(new JavaDate());\n\nvar year  = parseInt(dateStr.substring(0, 4), 10);\nvar month = parseInt(dateStr.substring(4, 6), 10);\nvar day   = parseInt(dateStr.substring(6, 8), 10);\n\n$runner.getLogger().info(\"[checkDayType] current datetime: \" + dateStr);\n\n// 曜日を取得（Java Calendar: 1=日, 2=月, ..., 7=土）\nvar cal = java.util.Calendar.getInstance(\n    java.util.TimeZone.getTimeZone(\"Asia/Tokyo\")\n);\ncal.set(year, month - 1, day, 0, 0, 0);\ncal.set(java.util.Calendar.MILLISECOND, 0);\nvar dayOfWeek = cal.get(java.util.Calendar.DAY_OF_WEEK);\n\nvar isSunday   = (dayOfWeek === java.util.Calendar.SUNDAY);\nvar isSaturday = (dayOfWeek === java.util.Calendar.SATURDAY);\n\n// 祝日API呼び出し\nvar isHoliday   = false;\nvar holidayName = \"\";\n\ntry {\n    var apiUrl = \"https://holidays-jp.github.io/api/v1/\" + year + \"/date.json\";\n\n    var client = HttpClient.newBuilder()\n        .connectTimeout(Duration.ofSeconds(10))\n        .build();\n\n    var request = HttpRequest.newBuilder()\n        .uri(URI.create(apiUrl))\n        .header(\"Accept\", \"application/json\")\n        .timeout(Duration.ofSeconds(10))\n        .GET()\n        .build();\n\n    var response = client.send(request, HttpResponse.BodyHandlers.ofString());\n\n    if (response.statusCode() === 200) {\n        var holidays = JSON.parse(response.body());\n\n        var mm = (month < 10 ? \"0\" : \"\") + month;\n        var dd = (day   < 10 ? \"0\" : \"\") + day;\n        var targetKey = year + \"-\" + mm + \"-\" + dd;\n\n        if (holidays[targetKey] !== undefined) {\n            isHoliday   = true;\n            holidayName = holidays[targetKey];\n        }\n    } else {\n        $runner.getLogger().warn(\"[checkDayType] API response: \" + response.statusCode());\n    }\n\n} catch (e) {\n    $runner.getLogger().error(\"[checkDayType] Holiday API error: \" + e.message);\n}\n\n// 判定（優先度: 日曜 > 祝日 > 土曜 > 平日）\nvar result;\n\nif (isSunday) {\n    result = \"sunday\";\n} else if (isHoliday) {\n    result = \"holiday\";\n} else if (isSaturday) {\n    result = \"saturday\";\n} else {\n    result = \"weekday\";\n}\n\n$runner.getLogger().info(\n    \"[checkDayType] date=\" + year + \"-\" + month + \"-\" + day +\n    \" dayOfWeek=\" + dayOfWeek +\n    \" isHoliday=\" + isHoliday +\n    (holidayName ? \"(\" + holidayName + \")\" : \"\") +\n    \" => \" + result\n);\n\n$runner.setResult(result);"
      }
    },
