        "取り消し",
        "とりけし",
        "やめ",
        "取りやめ",
        "とりやめ",
        "解除",
        "かいじょ"
      ],
      "patterns": [
        "(なし|無し)にして",
        "白紙に戻"
      ],
      "negatable": true
    },
    {
      "name": "operator",
      "patterns": [
        "(おぺれーたー|たんとうしゃ|にんげんのかた|まどぐち)(に|へ|と)?(つない|かわ|はなし|おねがい)"
      ]
    },
    {
      "name": "change_words_extra",
      "patterns": [
        "(別|べつ|ほか|他|違|ちが)(の|う)?日(程)?",
        "日を(改|あらた|延|のば|また)",
        "スケジュール(を|の)?(組み直|見直|調整)",
        "予定(を|の)?(見直|繰り上|組み直)",
        "いつもの(日|ひ)",
        "(今週|こんしゅう|今日|きょう)(じゃ|で)なく"
      ]
    },
    {
      "name": "cannot_visit",
      "patterns": [
        "(つごう|都合)が?(つかな(い|く)|わる(い|く)|あわな(い|く)|悪く)",
        "いけな(い|く)|行けな(い|く)",
        "(行か|いか)なきゃ",
        "間に合わな",
        "(難し|むずかし)くな",
        "終わらな",
        "(出張|しゅっちょう)",
        "(電車|でんしゃ|バス|ばす).*(止まっ|遅れ)",
        "(会議|かいぎ).*(入っ|はい)",
        "(シフト|しふと).*(変わ|合わな)",
        "(お腹|おなか).*(痛|いた)",
        "ばたばた",
        "別件",
        "無理",
        "ぎりぎり",
        "(天気|てんき).*(悪|わる)",
        "(予定|よてい)が(変わ|かわ)",
        "勘違い",
        "(仕事|しごと).*(休め|やすめ)",
        "親戚",
        "合わなく|合わない"
      ]
    },
    {
      "name": "future_date",
      "patterns": [
        "らいげつ|来月|らいしゅう|来週|べつのひ|別の日"
      ]
    },
    {
      "name": "inquiry_explicit",
      "keywords": [
        "質問",
        "しつもん",
        "問い合わせ",
        "といあわせ",
        "確認",
        "かくにん",
        "教えて",
        "おしえて",
        "相談",
        "そうだん",
        "聞きたい",
        "ききたい",
        "伺い",
        "うかがい",
        "知りたい",
        "しりたい",
        "よんばん",
        "待ち時間",
        "まちじかん",
        "いくら",
        "飛び込み",
        "とびこみ",
        "薬",
        "くすり",
        "れんとげん",
        "おうしん",
        "往診",
        "ふぁっくす"
      ],
      "patterns": [
        "(お聞き|おきき)(したい|してもいい)",
        "(分から|わから)(ない|なくて)",
        "(おしえてもらえますか|おしえていただけますか)",
        "(きいて|聞いて)(もいい|ていい|ください)",
        "どうすれば(いい|いいですか)",
        "(いた(い|かったり)|痛(い|かったり))"
      ]
    },
    {
      "name": "inquiry_vague",
      "patterns": [
        "ありますか",
        "いますか",
        "いけますか|行けますか",
        "どこですか|どこにありますか",
        "(ひつようですか|必要ですか)",
        "(みて|診て)(もらえますか|いただけますか|もらえる)",
        "(あいて|空いて)(いますか|ますか)",
        "(大丈夫|だいじょうぶ)ですか",
        "いつ(ですか|でしょうか|わかりますか|できますか)",
        "使えますか",
        "かかりますか|かかっちゃいますか",
        "(いつから|なんじから|何時から|なんじまで|何時まで|いつまで)",
        "(こんで|混んで)(ますか|いますか)",
        "(なんにちまえ|何日前)",
        "(やってます|やっています)(か|かね)?"
      ]
    }
  ],
  "events": [
