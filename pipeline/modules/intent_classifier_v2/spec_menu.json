{
  "question_type": "menu",
  "clarify_margin": 1,
  "numbers": {
    "1": "予約",
    "2": "変更",
    "3": "キャンセル",
    "4": "問い合わせ"
  },
  "synonyms": {
    "_YES_": [
      "はい",
      "ええ",
      "お願いします"
    ],
    "_NO_": [
      "いいえ",
      "結構です"
    ]
  },
  "extractors": [
    {
      "name": "birth_year",
      "regex": "(19[0-9][0-9]|20[0-9][0-9])(年|ねん)",
      "group": 1
    }
  ],
  "evidences": [
