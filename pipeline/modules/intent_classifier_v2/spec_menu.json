        "よやく",
        "予定だっ",
        "お願いしてた",
        "入れてた"
      ],
      "negatable": true
    },
    {
      "name": "change_words",
      "keywords": [
        "変更",
        "へんこう",
        "変え",
        "かえ",
        "取り直し",
        "とりなおし",
        "ずらし",
        "ずらす",
        "ずらせ",
        "リスケ",
        "りすけ",
        "振り替え",
        "ふりかえ",
        "ふりかえ",
        "振替",
