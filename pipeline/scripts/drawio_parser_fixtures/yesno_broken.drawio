<mxfile host="app.diagrams.net" agent="fixture (yesno broken: 否定 未配線)">
  <diagram name="シナリオフロー図" id="yaml_to_drawio_flow">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" page="1" pageWidth="900" pageHeight="700">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <object id="bo" label="冒頭" type="announce" repeat="無し" announce="お電話ありがとうございます。">
          <mxCell parent="1" style="rounded=1;" vertex="1"><mxGeometry height="44" width="180" x="360" y="60" as="geometry" /></mxCell>
        </object>
        <object id="kakunin" label="用件確認" type="question" repeat="無し" announce="この内容でよろしいですか。" output_format="enum" save_to="confirmResult" conditions_json="[{&quot;match&quot;: &quot;肯定&quot;, &quot;next&quot;: &quot;END_完了&quot;}, {&quot;match&quot;: &quot;NO_RESULT&quot;, &quot;next&quot;: &quot;聴取_用件&quot;}]">
          <mxCell parent="1" style="rounded=1;" vertex="1"><mxGeometry height="44" width="180" x="360" y="200" as="geometry" /></mxCell>
        </object>
        <object id="choshu" label="聴取_用件" type="item" repeat="無し" announce="ご用件をお話しください。" output_format="text" save_to="freeSpeech">
          <mxCell parent="1" style="rounded=1;" vertex="1"><mxGeometry height="44" width="180" x="120" y="340" as="geometry" /></mxCell>
        </object>
        <object id="end_ok" label="END_完了" type="end" repeat="無し" announce="承りました。ありがとうございました。">
          <mxCell parent="1" style="rounded=1;" vertex="1"><mxGeometry height="44" width="180" x="600" y="340" as="geometry" /></mxCell>
        </object>
        <mxCell edge="1" parent="1" source="bo" target="kakunin" style="endArrow=classic;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="kakunin" target="end_ok" style="endArrow=classic;" value="肯定"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="choshu" target="kakunin" style="endArrow=classic;"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
