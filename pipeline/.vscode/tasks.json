{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "VFB: 新規フロー作成 (/new-flow)",
      "detail": "テキスト貼り付け → CSV入力 → YAML生成まで Claude Code がガイド",
      "type": "shell",
      "command": "claude",
      "args": ["/new-flow ${input:facility} ${input:flow}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "VFB: CSV → YAML (既存施設)",
      "detail": "CSV が揃っている施設の YAML 再生成",
      "type": "shell",
      "command": "bash tools/run_csv_to_yaml.sh ${input:facility} ${input:flow}",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "VFB: QA Validate",
      "detail": "設計書 YAML の qa_validator を実行",
      "type": "shell",
      "command": "python3 schemas/qa_validator.py output/scenarios/${input:facility}_${input:flow}/設計書_${input:facility}_${input:flow}.yaml",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "facility",
      "description": "施設名を入力 (例: カレス記念病院)",
      "default": "",
      "type": "promptString"
    },
    {
      "id": "flow",
      "description": "フロー名を入力 (例: 診療)",
      "default": "診療",
      "type": "promptString"
    }
  ]
}
