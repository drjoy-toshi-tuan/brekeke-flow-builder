        <!-- ===== 横断FAQ レイヤー（手動追記。YAML 再生成では再描画されない）===== -->
        <mxCell id="faq_badge_1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#5E35B1;fontSize=10;fontStyle=1;arcSize=40;strokeWidth=1.5;" value="💬 質問→FAQ" vertex="1">
          <mxGeometry height="20" width="86" x="294" y="372" as="geometry" />
        </mxCell>
        <mxCell id="faq_badge_2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#5E35B1;fontSize=10;fontStyle=1;arcSize=40;strokeWidth=1.5;" value="💬 質問→FAQ" vertex="1">
          <mxGeometry height="20" width="86" x="174" y="892" as="geometry" />
        </mxCell>
        <mxCell id="faq_badge_3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#5E35B1;fontSize=10;fontStyle=1;arcSize=40;strokeWidth=1.5;" value="💬 質問→FAQ" vertex="1">
          <mxGeometry height="20" width="86" x="294" y="1152" as="geometry" />
        </mxCell>
        <mxCell id="faq_badge_4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#5E35B1;fontSize=10;fontStyle=1;arcSize=40;strokeWidth=1.5;" value="💬 質問→FAQ" vertex="1">
          <mxGeometry height="20" width="86" x="414" y="892" as="geometry" />
        </mxCell>
        <mxCell id="faq_note_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#4527A0;fontSize=11;align=left;verticalAlign=top;spacing=10;arcSize=6;strokeWidth=2;" value="&lt;b&gt;💬 横断FAQ（質問検知）&lt;/b&gt;&lt;br&gt;&lt;br&gt;個人情報入力以外の各聴取で、回答の代わりに&lt;b&gt;質問形式&lt;/b&gt;の発話が来たら、FAQを検索して回答し&lt;b&gt;元の聴取に復帰&lt;/b&gt;する（横串で全体に適用）。&lt;br&gt;&lt;br&gt;&lt;b&gt;実装:&lt;/b&gt; 決定論 FAQ Matcher（OpenAI不使用・NFKC+2-gram+BM25）。&lt;b&gt;実機PoC検証済&lt;/b&gt;。出力&lt;b&gt;4分岐&lt;/b&gt;で「回答→復帰／質問でない→次へ／答えられない→未回答フラグを立て次へ」。&lt;br&gt;&lt;br&gt;&lt;b&gt;💬 質問→FAQ バッジ&lt;/b&gt; = この聴取に横断FAQを配置。対象は 用件フリー聴取／聴取_診療科／聴取_予約希望日／聴取_予約日時。&lt;b&gt;個人情報の入力（氏名・連絡先・生年月日・診察券番号）には置かない&lt;/b&gt;（番号読み上げ等の誤検知回避）。&lt;br&gt;&lt;br&gt;&lt;b&gt;終話:&lt;/b&gt; 答えられない質問があれば末尾の『終話判定』が END_問い合わせ折り返し を選ぶ（決定論・OpenAI不使用）。&lt;br&gt;&lt;br&gt;&lt;i&gt;※この横断FAQ層は手動追記。設計書YAMLからの再生成では再描画されません。&lt;/i&gt;" vertex="1">
          <mxGeometry height="420" width="340" x="600" y="250" as="geometry" />
        </mxCell>
