oduleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""}],"subs":[{"moduleName":"","label":""},{"moduleName":"","label":""},{"moduleName":"","label":""}],"name":"OpenAI_現在の予約日","description":"","matchingmethod":1,"type":"drjoy^External Integration$generate_by_OpenAI","params":{"module":"入力_現在の予約日","prompt":"","functionCall":"","promptTTS":"","contextName":"reservationDate","contextDisplayType":"DATE"}},"script_当日判定":{"layout":{"x":3420,"y":0},"next":[{"condition":"^SUCCESS$","label":"SUCCESS","nextModuleName":"完了フラグ_キャンセル完了"},{"condition":"^FAIL$","label":"FAIL","nextModuleName":"完了フラグ_当日キャンセル"},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""}],"subs":[{"moduleName":"","label":""},{"moduleName":"","label":""},{"moduleName":"","label":""}],"name":"script_当日判定","description":"","matchingmethod":1,"type":"@General$Script","params":{"module":"OpenAI_現在の予約日","script":"// Script Template: future_date\n// 入力モジュールから取得した日付が今日より未来か判定\n// プレースホルダー: OpenAI_現在の予約日 = 入力元モジュール名\n// 出力: SUCCESS（未来日付）/ FAIL（今日以前 or 解釈不能）\n\n// 1. 前のモジュールからデータを取得\nvar input = $runner.getModuleResult(\"OpenAI_現在の予約日\");\nvar res = \"FAIL\";\n\nif (input) {\n    var inputStr = input.toString().trim();\n    var finalInputDate = \"\";\n\n    // 2. 入力値を yyyy-MM-dd 形式に正規化\n    if (inputStr.length === 8 && /^\\d{8}$/.test(inputStr)) {\n        // 8桁数字: yyyyMMdd → yyyy-MM-dd\n        finalInputDate = inputStr.substring(0, 4) + \"-\" +\n                         inputStr.substring(4, 6) + \"-\" +\n                         inputStr.substring(6, 8);\n    } else if (inputStr.length >= 10) {\n        // yyyy-MM-dd HH:mm 形式 → 先頭10文字（yyyy-MM-dd）のみ\n        finalInputDate = inputStr.substring(0, 10);\n    }\n\n    // 3. 現在日付を yyyy-MM-dd 形式で取得\n    var now = new Date();\n    var year = now.getFullYear();\n    var month = (\"0\" + (now.getMonth() + 1)).slice(-2);\n    var day = (\"0\" + now.getDate()).slice(-2);\n    var todayDate = year + \"-\" + month + \"-\" + day;\n\n    // 4. 比較: 今日より後の日付なら SUCCESS\n    if (finalInputDate > todayDate) {\n        res = \"SUCCESS\";\n    } else {\n        res = \"FAIL\";\n    }\n}\n\n// 5. 結果をセット\n$runner.setResult(res);\n"}},"確認_診療科":{"layout":{"x":1120,"y":3600},"next":[{"condition":"^.*$","label":"Next Module","nextModuleName":"入力_確認_診療科"}],"subs":[{"moduleName":"save-clinicalDepartment","label":"save-clinicalDepartment"},{"moduleName":"","label":""},{"moduleName":"","label":""}],"name":"確認_診療科","description":"","matchingmethod":1,"type":"drjoy^Text To Speech$Text to speech","params":{"prompt":"","stop_by_dtmf":"No","category_words":""}},"入力_確認_診療科":{"layout":{"x":1120,"y":3750},"next":[{"condition":"^TIMEOUT$","label":"timeout","nextModuleName":"リトライ_確認_診療科"},{"condition":"^ERROR$","label":"error","nextModuleName":"リトライ_確認_診療科"},{"condition":"^NO_RESULT$","label":"no_result","nextModuleName":"saveDefault-入力_確認_診療科"},{"condition":"^.+$","label":"success","nextModuleName":"OpenAI_確認_診療科"},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""},{"condition":"","label":"","nextModuleName":""}],"subs":[{"moduleName":"save-clinicalDepartment","label":"save-clinicalDepartment"},{"moduleName":"","label":""},{"moduleName":"","label":""}],"name":"入力_確認_診療科","description":"","matchingmethod":1,"type":"drjoy^AmiVoice$Speech to Text","params":{"uri"